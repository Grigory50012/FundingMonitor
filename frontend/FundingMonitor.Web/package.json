{
  "name": "fundingmonitor-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check:api-types": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/check-openapi-contract.ps1",
    "generate:api-types": "openapi-typescript ../../openapi/funding-monitor-v1.json -o src/types/generated/api.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "openapi-typescript": "7.10.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vitest": "3.2.4"
  }
}
