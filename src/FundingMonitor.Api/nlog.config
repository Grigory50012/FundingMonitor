<?xml version="1.0" encoding="utf-8" ?>
<!--
  NLog Configuration
  Schema: https://raw.githubusercontent.com/NLog/NLog/master/src/NLog/resources/NLog.xsd
  
  Для включения IntelliSense в Rider:
  Settings → Languages & Frameworks → Schemas and DTDs → Add URL выше
-->
<nlog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      throwConfigExceptions="true">

    <targets>
        <!-- ==================== ОШИБКИ ==================== -->
        <target xsi:type="File"
                name="errors"
                fileName="logs/${shortdate}/errors.log"
                layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString,StackTrace}|${all-event-properties}"
                archiveFileName="logs/archive/errors.{#}.log"
                archiveEvery="Day"
                maxArchiveFiles="30"/>

        <!-- ==================== ЗАПУСК ==================== -->
        <target xsi:type="File"
                name="startup"
                fileName="logs/${shortdate}/startup.log"
                layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}|${all-event-properties}"
                archiveFileName="logs/archive/startup.{#}.log"
                archiveEvery="Day"
                maxArchiveFiles="14"/>

        <!-- ==================== СБОР ДАННЫХ ==================== -->
        <target xsi:type="File"
                name="collection"
                fileName="logs/${shortdate}/collection.log"
                layout="${longdate}|${level:uppercase=true}|${message} ${exception:format=ToString}|${all-event-properties}"
                archiveFileName="logs/archive/collection.{#}.log"
                archiveEvery="Day"
                maxArchiveFiles="14"/>

        <!-- ==================== API ЗАПРОСЫ ==================== -->
        <target xsi:type="File"
                name="api"
                fileName="logs/${shortdate}/api.log"
                layout="${longdate}|${level:uppercase=true}|${message} ${exception:format=ToString}|${all-event-properties}"
                archiveFileName="logs/archive/api.{#}.log"
                archiveEvery="Day"
                maxArchiveFiles="14"/>

        <!-- ==================== ОТЛАДКА ==================== -->
        <target xsi:type="File"
                name="debug"
                fileName="logs/${shortdate}/debug.log"
                layout="${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}|${all-event-properties}"
                archiveFileName="logs/archive/debug.{#}.log"
                archiveEvery="Day"
                maxArchiveFiles="7"/>

        <!-- ==================== КОНСОЛЬ ==================== -->
        <target xsi:type="Console"
                name="console"
                layout="${longdate}|${level:uppercase=true}|${logger:shortName=true}|${message} ${exception:format=ToString}"/>
    </targets>

    <rules>
        <!-- ==================== ОШИБКИ (всегда) ==================== -->
        <logger name="*" minlevel="Error" writeTo="errors"/>

        <!-- ==================== ЗАПУСК (только миграции и хостинг) ==================== -->
        <logger name="Microsoft.EntityFrameworkCore.Migrations" minlevel="Info" writeTo="startup"/>
        <logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="startup"/>

        <!-- ==================== СБОР ДАННЫХ ==================== -->
        <logger name="FundingMonitor.Application.Services.CurrentFundingRateCollector" minlevel="Info"
                writeTo="collection"/>
        <logger name="FundingMonitor.Application.BackgroundServices.CurrentCollectionBackgroundService" minlevel="Info"
                writeTo="collection"/>
        <logger name="FundingMonitor.Application.BackgroundServices.HistoricalCollectionBackgroundService"
                minlevel="Info" writeTo="collection"/>
        <logger name="FundingMonitor.Infrastructure.ExchangeClients.*" minlevel="Debug" writeTo="collection"/>
        <logger name="FundingMonitor.Infrastructure.Data.Repositories.*" minlevel="Debug" writeTo="collection"/>

        <!-- ==================== API ЗАПРОСЫ ==================== -->
        <logger name="FundingMonitor.Api.Controllers.*" minlevel="Info" writeTo="api"/>
        <logger name="Microsoft.AspNetCore.Hosting.Diagnostics" minlevel="Info" writeTo="api"/>
        <logger name="Microsoft.AspNetCore.Routing.*" minlevel="Info" writeTo="api"/>
        <logger name="Microsoft.AspNetCore.Cors.*" minlevel="Info" writeTo="api"/>

        <!-- ==================== ОТЛАДКА (раскомментировать для dev) ==================== -->
        <!-- <logger name="*" minlevel="Debug" writeTo="debug" /> -->

        <!-- ==================== КОНСОЛЬ (только наше) ==================== -->
        <logger name="FundingMonitor.*" minlevel="Info" writeTo="console" final="true"/>
    </rules>
</nlog>
