{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=funding_monitor;Username=postgres;Password=postgres;Maximum Pool Size=20;Connection Idle Lifetime=300;"
  },
  "CurrentDataCollectionOptions": {
    "UpdateIntervalSeconds": 10
  },
  "HistoricalDataCollectionOptions": {
    "MaxConcurrentTasks": 10,
    "ApiPageSize": 1000,
    "MaxHistoryMonths": 1,
    "MaxRetries": 3
  },
  "NLog": {
    "throwConfigExceptions": true,
    "targets": {
      "file_all": {
        "type": "File",
        "fileName": "logs/${shortdate}/all.log",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString}",
        "archiveFileName": "logs/archive/all.{#}.log",
        "archiveEvery": "Day",
        "archiveNumbering": "Rolling",
        "maxArchiveFiles": 7
      },
      "file_current": {
        "type": "File",
        "fileName": "logs/${shortdate}/current.log",
        "layout": "${longdate}|${message}",
        "archiveFileName": "logs/archive/current.{#}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 7
      },
      "file_historical": {
        "type": "File",
        "fileName": "logs/${shortdate}/historical.log",
        "layout": "${longdate}|${message}",
        "archiveFileName": "logs/archive/historical.{#}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 7
      },
      "file_binance": {
        "type": "File",
        "fileName": "logs/${shortdate}/binance.log",
        "layout": "${longdate}|${message}",
        "archiveFileName": "logs/archive/binance.{#}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 7
      },
      "file_bybit": {
        "type": "File",
        "fileName": "logs/${shortdate}/bybit.log",
        "layout": "${longdate}|${message}",
        "archiveFileName": "logs/archive/bybit.{#}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 7
      },
      "file_errors": {
        "type": "File",
        "fileName": "logs/${shortdate}/errors.log",
        "layout": "${longdate}|${level:uppercase=true}|${logger}|${message} ${exception:format=ToString,StackTrace}",
        "archiveFileName": "logs/archive/errors.{#}.log",
        "archiveEvery": "Day",
        "maxArchiveFiles": 30
      },
      "console": {
        "type": "Console",
        "layout": "${longdate}|${level:uppercase=true}|${message} ${exception:format=ToString}"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Info",
        "maxLevel": "Fatal",
        "writeTo": "file_all"
      },
      {
        "logger": "*",
        "minLevel": "Error",
        "maxLevel": "Fatal",
        "writeTo": "file_errors"
      },
      {
        "logger": "FundingMonitor.Application.Services.CurrentFundingRateCollector",
        "minLevel": "Debug",
        "writeTo": "file_current"
      },
      {
        "logger": "FundingMonitor.Application.Services.CurrentFundingRateCollector",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Application.BackgroundServices.HistoricalCollectionBackgroundService",
        "minLevel": "Debug",
        "writeTo": "file_historical"
      },
      {
        "logger": "FundingMonitor.Application.Services.FundingRateHistoryService",
        "minLevel": "Debug",
        "writeTo": "file_historical"
      },
      {
        "logger": "FundingMonitor.Application.BackgroundServices.HistoricalCollectionBackgroundService",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Application.Services.FundingRateHistoryService",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.ExchangeClients.BinanceFundingRateClient",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.ExchangeClients.BinanceFundingRateClient",
        "minLevel": "Debug",
        "writeTo": "file_binance"
      },
      {
        "logger": "FundingMonitor.Infrastructure.ExchangeClients.BybitFundingRateClient",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.ExchangeClients.BybitFundingRateClient",
        "minLevel": "Debug",
        "writeTo": "file_bybit"
      },
      {
        "logger": "FundingMonitor.Infrastructure.Data.Repositories.HistoricalFundingRateRepository",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.Data.Repositories.CurrentFundingRateRepository",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.Queues.InMemoryHistoryTaskQueue",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Infrastructure.State.InMemorySymbolStateRepository",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "FundingMonitor.Application.Services.ExchangeAvailabilityChecker",
        "minLevel": "Debug",
        "writeTo": "file_all"
      },
      {
        "logger": "Microsoft.EntityFrameworkCore.*",
        "minLevel": "Warning",
        "maxLevel": "Fatal",
        "writeTo": "file_errors"
      },
      {
        "logger": "Microsoft.EntityFrameworkCore.*",
        "minLevel": "Warning",
        "maxLevel": "Fatal",
        "writeTo": "file_all"
      },
      {
        "logger": "*",
        "minLevel": "Info",
        "writeTo": "console",
        "final": true
      }
    ]
  },
  "AllowedHosts": "*"
}
